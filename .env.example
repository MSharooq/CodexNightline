# Add actual values to .dev.vars for local Cloudflare Worker development.
# For production, use `npx wrangler secret put KEY_NAME` — never commit credentials.

# Bolna voice agent (required when replacing the demo voice flow)
BOLNA_API_KEY=
BOLNA_AGENT_ID=
BOLNA_FROM_PHONE_NUMBER=
BOLNA_FUNCTION_TOKEN=

# Public support number in E.164 format. It is returned by /api/public-config
# so the browser can render a tel: link. This is not an API secret.
SAHAAYI_PHONE_NUMBER=

# AI case and benefit routing (optional while demo routing is enabled).
# Keep this server-side: do not use a VITE_ prefix for either variable.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna

# Supabase (required when replacing the demo data store)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: verified support-centre maps and distance lookup
MAPBOX_ACCESS_TOKEN=
